#!/usr/bin/env python3
"""meta-gbp: manages mainline releases for Dockershelf Go packaging.

Follows the python-pipeline / node-pipeline submodule pattern:
  - go/ is a git submodule pointing to golang/go (release-branch.go1.X)
  - `update` fetches upstream, finds the latest go1.X.Y tag, checks it out
    in the submodule, updates changelogs, and commits the new pointer
  - `materialize` creates a work/ tree with the Go source + debian/ packaging
  - `build` runs gbp buildpackage inside the Docker builder container
"""
from __future__ import annotations

import argparse
import functools
import os
import os.path
import re
import shlex
import shutil
import subprocess
import sys
import tempfile
from typing import NamedTuple

_DIRNAME_PAT = re.compile(r'^go(\d+\.\d+)$')
UPSTREAM_TAG_PREFIX = 'dockershelf/v'

VERSION_RE = re.compile(r'^go(\d+\.\d+\.\d+)((?:rc|beta)\d+)?(.*)$')
CHANGELOG_VERSION_RE = re.compile(r'^(.*)-1\+')

HERE = os.path.abspath(os.path.dirname(__file__))
BUILD = os.path.join(HERE, 'build')
TOOLS = os.path.join(HERE, 'tools')
RESOLVE_PATCH = os.path.join(HERE, 'scripts', 'resolve-go-patch.py')


@functools.lru_cache
def _go_minor() -> str:
    dirname = os.path.basename(os.getcwd())
    match = _DIRNAME_PAT.match(dirname)
    if not match:
        raise SystemExit(f'not a meta-gbp repo? expected go#.# dir: {dirname}')
    return match[1]


class Version(NamedTuple):
    version: str
    extra: str

    @property
    def pkg_name(self) -> str:
        return f'golang-{_go_minor()}-go'

    @property
    def debian_version(self) -> str:
        extra = f'~{self.extra}' if self.extra else ''
        return f'{self.version}{extra}'

    @property
    def filename(self) -> str:
        return f'go{self.debian_version}.src.tar.gz'

    @property
    def download_url(self) -> str:
        return f'https://go.dev/dl/{self.filename}'

    @classmethod
    def parse(cls, s: str) -> Version:
        match = VERSION_RE.fullmatch(s)
        if not match or _is_dev_snapshot(match):
            raise ValueError(
                f'expected a release tag (e.g. go1.22.5), got {s}; '
                'checkout go at an upstream release tag'
            )
        return cls(match[1], match[2])


def _is_prerelease(v_match: re.Match[str]) -> bool:
    return bool(v_match[2])


def _is_dev_snapshot(v_match: re.Match[str]) -> bool:
    """True when describe is past a tag (e.g. go1.22.5-41-gabc123)."""
    return bool(v_match[3])


def _describe_at(rev: str) -> re.Match[str]:
    git = ('git', '-C', 'go')
    tag = _cmd_o(
        *git, 'describe', '--abbrev=10', '--tags', '--match', 'go*', rev,
    ).rstrip()
    match = VERSION_RE.fullmatch(tag)
    if match is None:
        raise SystemExit(f'Unexpected tag at {rev}: {tag}')
    return match


def _p_cmd(cmd: tuple[str, ...], cwd: str | None) -> None:
    cwd_s = f'({cwd})' if cwd else ''
    print(f'{cwd_s}+ {shlex.join(cmd)}', file=sys.stderr)


def _cmd_q(*cmd: str, cwd: str | None = None) -> None:
    _p_cmd(cmd, cwd)
    ret = subprocess.call(
        cmd,
        cwd=cwd,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    if ret:
        raise SystemExit(f'`{shlex.join(cmd)}` raised {ret}')


def _cmd_o(*cmd: str, cwd: str | None = None) -> str:
    _p_cmd(cmd, cwd)
    ret = subprocess.run(cmd, cwd=cwd, stdout=subprocess.PIPE, text=True)
    if ret.returncode:
        raise SystemExit(f'`{shlex.join(cmd)}` raised {ret.returncode}')
    return ret.stdout


def _cmd_r(*cmd: str, cwd: str | None) -> int:
    _p_cmd(cmd, cwd)
    return subprocess.call(cmd, cwd=cwd)


def _validate_meta_gbp_dir() -> None:
    for path in (
        'changelogs/mainline',
        'debiandirs',
    ):
        if not os.path.exists(path):
            raise SystemExit(f'not a meta-gbp repo? missing ./{path}')

    assert _go_minor()


def _likely_go_clone(d: str) -> bool:
    return os.path.isdir(d) and os.path.exists(os.path.join(d, 'src', 'make.bash'))


def _potential_go_clone() -> str | None:
    if _likely_go_clone('../../go'):
        return '../../go'

    for dname in os.listdir('..'):
        if dname.startswith('go') and dname[2:].replace('.', '').isdigit():
            dname = os.path.abspath(os.path.join('..', dname, 'go'))
            if _likely_go_clone(dname):
                return dname

    return None


def _reference_args() -> tuple[str, ...]:
    go_dir = _potential_go_clone()
    if go_dir is not None:
        return ('--reference', go_dir, '--dissociate')
    else:
        return ()


def _ensure_submodule_available(*, required: bool = False) -> None:
    if _likely_go_clone('go'):
        return
    if not required:
        return
    if not os.path.exists('.gitmodules'):
        raise SystemExit('go submodule required; run init-go-submodules.sh')
    _cmd_q('git', 'submodule', 'update', '--init', *_reference_args())
    if _cmd_r('git', 'diff', '--quiet', '--no-ext-diff', 'go'):
        _cmd_q('git', 'submodule', 'update', '--init')


def _current_tag() -> re.Match[str]:
    git = ('git', '-C', 'go')
    tag_cmd = (*git, 'describe', '--abbrev=10', '--tags', '--match', 'go*')
    tag = _cmd_o(*tag_cmd).rstrip()
    match = VERSION_RE.fullmatch(tag)
    if match is None:
        raise SystemExit(f'Unexpected tag: {tag}')

    minor = _go_minor()
    if not match[1].startswith(f'{minor}.'):
        raise SystemExit(
            f'go submodule is at {match[1]} but repo is go{minor}; '
            f'checkout release-branch.go{minor} in the go/ submodule'
        )

    return match


def _resolve_latest_patch(minor: str) -> str:
    return subprocess.check_output(
        (sys.executable, RESOLVE_PATCH, minor),
        text=True,
    ).strip()


def _ignore_git(_dir: str, names: list[str]) -> set[str]:
    return {'.git'} if '.git' in names else set()


def _mainline_repo(dist: str) -> int:
    _cmd_q('rm', '-rf', 'work')
    os.makedirs('work', exist_ok=True)

    shutil.copytree('go', 'work/go', symlinks=True, ignore=_ignore_git)
    shutil.copytree(f'debiandirs/{dist}', 'work/debian')
    shutil.copy(f'changelogs/mainline/{dist}', 'work/debian/changelog')
    if os.path.isdir('patches') and os.listdir('patches'):
        shutil.copytree('patches', 'work/debian/patches')

    _cmd_q('git', 'init', 'work')
    git = ('git', '-C', 'work')
    _cmd_q(*git, 'add', '-A')
    _cmd_q(*git, 'commit', '-q', '-m', f'meta-gbp: init for {dist}')

    return 0


def _materialize(dist: str) -> int:
    return _mainline_repo(dist)


def _patch_queue_worktree() -> int:
    """Minimal debian/ tree for gbp pq during meta-gbp update."""
    _cmd_q('rm', '-rf', 'work')
    _cmd_q('git', 'clone', 'go', 'work')

    git = ('git', '-C', 'work')

    _cmd_q(*git, 'branch', 'upstream')

    v_match = _current_tag()
    if _is_prerelease(v_match):
        new_tag = f'{UPSTREAM_TAG_PREFIX}{v_match[1]}_{v_match[2]}{v_match[3]}'
    else:
        new_tag = f'{UPSTREAM_TAG_PREFIX}{v_match[1]}{v_match[3]}'
    _cmd_q(*git, 'tag', new_tag)

    _cmd_q(*git, 'checkout', '-b', 'debian/unknown')

    os.makedirs('work/debian')
    open('work/debian/control', 'a+').close()
    if os.path.isdir('patches') and os.listdir('patches'):
        shutil.copytree('patches', 'work/debian/patches')

    _cmd_q(*git, 'add', 'debian')
    _cmd_q(*git, 'commit', '-q', '-m', 'meta-gbp: init')

    return 0


def _update_target() -> str:
    git = ('git', '-C', 'go')
    minor = _go_minor()
    branch = f'release-branch.go{minor}'

    fetch = (*git, 'fetch', 'origin')

    try:
        _cmd_q(*fetch, f'refs/heads/{branch}:refs/heads/go-upstream')
    except SystemExit:
        try:
            _cmd_q(*fetch, f'refs/tags/{branch}:refs/tags/{branch}')
            _cmd_q(*git, 'update-ref', 'refs/heads/go-upstream', f'{branch}~0')
            _cmd_q(*git, 'tag', '--delete', branch)
        except SystemExit:
            _cmd_q(*fetch, 'refs/heads/master:refs/heads/go-upstream')

    current = _cmd_o(*git, 'rev-parse', 'HEAD').strip()

    for rev in _cmd_o(
        *git, 'log',
        '--reverse',
        '--decorate-refs=refs/tags/',
        '--format=%H',
        '--simplify-by-decoration',
        'HEAD..go-upstream',
    ).splitlines():
        if rev == current:
            continue
        if not _is_dev_snapshot(_describe_at(rev)):
            return rev

    return current


def _pin_go_to_release_tag() -> str | None:
    """If go HEAD is past a tag, check out that release tag. Returns tag name."""
    git = ('git', '-C', 'go')
    head = _cmd_o(*git, 'rev-parse', 'HEAD').strip()
    if not _is_dev_snapshot(_describe_at(head)):
        return None
    tag = _cmd_o(*git, 'describe', '--abbrev=0', '--tags', '--match', 'go*').strip()
    if _cmd_o(*git, 'rev-parse', tag).strip() == head:
        return None
    _cmd_q(*git, 'checkout', tag)
    return tag


def _update(*, rev: str | None, interactive: bool) -> int:
    if rev is None:
        rev = _update_target()

    current_rev = _cmd_o('git', '-C', 'go', 'rev-parse', 'HEAD').strip()
    if current_rev == rev:
        pinned = _pin_go_to_release_tag()
        if pinned is not None:
            _cmd_q('git', 'add', 'go')
            _cmd_q('git', 'commit', '-m', f'go: pin to release {pinned}')
        print('already up to date!', file=sys.stderr)
        return 0

    _patch_queue_worktree()

    git_work = ('git', '-C', 'work')

    if os.path.isdir('patches') and os.listdir('patches'):
        _cmd_q(TOOLS, 'gbp', 'pq', 'import', cwd='work')
        _cmd_q(*git_work, 'checkout', '-')

    _cmd_q(*git_work, 'merge', rev)

    if os.path.isdir('patches') and os.listdir('patches') and _cmd_r(TOOLS, 'gbp', 'pq', 'rebase', cwd='work'):
        if not interactive:
            return 1

        print('*' * 79)
        print('Did not rebase cleanly!')
        print('- to cancel: `git rebase --abort` and `exit 1`')
        print('- to continue: resolve the rebase conflicts and `exit 0`')
        print('*' * 79)
        ret = _cmd_r(os.environ.get('SHELL', 'bash'), cwd='work')
        if ret:
            return ret

    if os.path.isdir('patches') and os.listdir('patches'):
        _cmd_q(TOOLS, 'gbp', 'pq', 'export', cwd='work')
        _cmd_q('rm', '-rf', 'patches')
        shutil.copytree('work/debian/patches', 'patches')

    _cmd_q('git', '-C', 'go', 'checkout', rev)

    v_match = _current_tag()

    for dist in os.listdir('changelogs/mainline'):
        if _is_prerelease(v_match):
            debian_version = f'{v_match[1]}~{v_match[2]}{v_match[3]}-1+{dist}1'
        else:
            debian_version = f'{v_match[1]}{v_match[3]}-1+{dist}1'
        _cmd_q(
            TOOLS, 'dch',
            '--newversion', debian_version,
            '--distribution', dist,
            '--force-distribution',
            '--changelog', f'changelogs/mainline/{dist}',
            f'Update to {v_match[0]}.',
        )

    _cmd_q('git', 'add', 'changelogs', 'go')
    if os.path.isdir('patches'):
        _cmd_q('git', 'add', 'patches')
    _cmd_q('git', 'commit', '-m', f'update to {rev} (mainline)')

    return 0


def _changelog(message: str, *, only: str | None) -> int:
    for dist in os.listdir('changelogs/mainline'):
        if only is not None and dist != only:
            continue
        current_version = _cmd_o(
            TOOLS, 'dpkg-parsechangelog',
            '--file', f'changelogs/mainline/{dist}',
            '--show-field=version',
        ).strip()

        parsed = re.fullmatch(r'^(.*)-1\+([a-z]+)([0-9]+)$', current_version)
        if parsed is None:
            raise SystemExit(f'unexpected version: {current_version}')

        if parsed[2] != dist:
            new = 1
        else:
            new = int(parsed[3]) + 1

        _cmd_q(
            TOOLS, 'dch',
            '--newversion', f'{parsed[1]}-1+{dist}{new}',
            '--distribution', dist,
            '--force-distribution',
            '--changelog', f'changelogs/mainline/{dist}',
            message,
        )

    return 0


def _build() -> int:
    if not os.path.exists('work/debian/rules'):
        raise SystemExit('not materialized?')

    _cmd_q('rm', '-rf', 'dist')

    return _cmd_r(BUILD, cwd='work')


def main() -> int:
    _validate_meta_gbp_dir()

    dists = sorted(os.listdir('changelogs/mainline'))

    parser = argparse.ArgumentParser()

    subparsers = parser.add_subparsers(dest='command', required=True)

    subparsers.add_parser('build')

    changelog = subparsers.add_parser('changelog')
    changelog.add_argument('-m', '--message', required=True)
    changelog.add_argument('--only', choices=dists)

    materialize = subparsers.add_parser('materialize')
    materialize.add_argument('dist', choices=dists)

    update = subparsers.add_parser('update')
    update.add_argument('--rev')
    update.add_argument(
        '--no-interactive',
        dest='interactive',
        action='store_false',
    )

    args = parser.parse_args()

    if args.command == 'update':
        _ensure_submodule_available(required=True)
        return _update(rev=args.rev, interactive=args.interactive)

    _ensure_submodule_available()

    if args.command == 'build':
        return _build()
    if args.command == 'changelog':
        return _changelog(args.message, only=args.only)
    if args.command == 'materialize':
        return _materialize(args.dist)

    raise NotImplementedError(f'{args.command=}')


if __name__ == '__main__':
    raise SystemExit(main())
