#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import os.path
import subprocess
from typing import NoReturn

HERE = os.path.abspath(os.path.dirname(__file__))
TOOLS = os.path.join(HERE, 'tools')
DOCKER_RUN = os.path.join(HERE, 'docker-run')

BUILDER_IMAGE = os.environ.get('DOCKERSHELF_BUILDER_IMAGE', 'ghcr.io/dockershelf/dockershelf-go-builder')
ARCH = os.environ.get('DOCKERSHELF_ARCH', 'amd64')


def _gpg_volumes() -> list[str]:
    def _gpg(f: str, *, home: str = os.path.expanduser('~')) -> str:
        return os.path.join(home, '.gnupg', f)

    for paths in (
        ('pubring.kbx', 'private-keys-v1.d'),
        ('pubring.gpg', 'secring.gpg'),
    ):
        if all(os.path.exists(_gpg(p)) for p in paths):
            return [
                f'--volume={_gpg(p)}:{_gpg(p, home="/root")}:ro'
                for p in paths
            ]
    return []


def main() -> NoReturn:
    parser = argparse.ArgumentParser()
    parser.parse_args()

    print('*' * 79)
    print('Parsing target distribution')
    print('*' * 79)
    dist = subprocess.check_output((
        TOOLS, 'dpkg-parsechangelog', '--show-field=distribution',
    )).decode().strip()

    pwd = os.getcwd()
    dist_dir = os.path.join(HERE, 'dist')

    print('*' * 79)
    print(f'Running build for {ARCH} (results will be in {dist_dir})')
    print('*' * 79)
    os.makedirs(dist_dir, exist_ok=True)
    # Filter out _all.deb on non-amd64 arches (built only on amd64 to avoid duplicates)
    deb_filter = '-name "*.deb"'
    if ARCH != 'amd64':
        deb_filter = '-name "*.deb" ! -name "*_all.deb"'
    prog = (
        f'apt-get update -qq && '
        f'mk-build-deps --install --remove --tool "apt-get --yes" /code/debian/control && '
        f'mkdir -p /tmp/build && '
        f'cp -a /code/go /code/debian /tmp/build/ && '
        f'cd /tmp/build && '
        f'dpkg-buildpackage -us -uc -b && '
        f'find .. -maxdepth 1 -type f \\( {deb_filter} -o -name "*.changes" \\) '
        f'-exec cp {{}} /dist/ \\;'
    )
    cmd = (
        DOCKER_RUN,
        '--platform', f'linux/{ARCH}',
        *_gpg_volumes(),
        '-v', f'{pwd}:/code:ro',
        '-v', f'{dist_dir}:/dist:rw',
        f'{BUILDER_IMAGE}/{dist}', 'bash', '-euxc', prog,
    )
    os.execvp(cmd[0], cmd)


if __name__ == '__main__':
    raise SystemExit(main())
